# FuzeAgent Local Deployment Environment Variables

# Database Configuration
POSTGRES_PASSWORD=fuzeagent_local_2024
RABBITMQ_PASSWORD=fuzeagent_rabbit_2024
REDIS_PASSWORD=fuzeagent_redis_2024

# API Keys (Required for AI features)
ANTHROPIC_API_KEY=your-api-key-here
OPENAI_API_KEY=your-openai-key-here
GOOGLE_API_KEY=your-google-key-here

# Security
JWT_SECRET=fuzeagent_jwt_secret_local_2024
ENCRYPTION_KEY=fuzeagent_encryption_key_local_2024

# Environment
NODE_ENV=development
DEBUG=true

# Claude Code Configuration
CLAUDE_CODE_ENABLE_TELEMETRY=1
CLAUDE_CODE_WORKSPACE_ID=fuzeagent
CLAUDE_CODE_PROJECT_NAME=FuzeAgent

# Feature Flags
ENABLE_AUTONOMOUS_EXECUTION=true
ENABLE_MULTI_AGENT_COORDINATION=true
ENABLE_FILE_OPERATIONS=true
ENABLE_MCP_INTEGRATION=true

# Resource Limits
MAX_CONCURRENT_EXECUTIONS=10
MAX_COORDINATION_SESSIONS=5
