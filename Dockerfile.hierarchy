FROM python:3.11-slim

# Set working directory
WORKDIR /app

# Install dependencies
COPY requirements-hierarchy.txt .
RUN pip install --no-cache-dir -r requirements-hierarchy.txt

# Copy the auth module (shared with orchestrator) and the hierarchy API
COPY services/orchestrator/auth.py .
COPY hierarchy_endpoints.py .

# Expose port
EXPOSE 8006

# Run the application
CMD ["python", "hierarchy_endpoints.py"]