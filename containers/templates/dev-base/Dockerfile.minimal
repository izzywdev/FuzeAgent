FROM ubuntu:22.04

# Avoid interactive prompts during install
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# Install only essential packages
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create agent user
RUN useradd -l -u 1000 -m -s /bin/bash agent

# Set up workspace directory
RUN mkdir -p /workspaces && chown agent:agent /workspaces

# Install only core Python dependencies (without ML libraries for testing)
RUN pip3 install --no-cache-dir \
    aiohttp>=3.8.0 \
    asyncpg>=0.28.0 \
    pydantic>=2.0.0 \
    python-dotenv>=1.0.0 \
    anthropic>=0.21.0

# Copy a simple test script
RUN echo '#!/usr/bin/env python3' > /usr/local/bin/test_agent.py && \
    echo 'print("🤖 FuzeAgent Memory System Container Ready!")' >> /usr/local/bin/test_agent.py && \
    echo 'print("   - Python:", __import__("sys").version.split()[0])' >> /usr/local/bin/test_agent.py && \
    echo 'print("   - Packages: aiohttp, asyncpg, pydantic, anthropic")' >> /usr/local/bin/test_agent.py && \
    echo 'print("   - Ready for memory-enabled agent deployment")' >> /usr/local/bin/test_agent.py && \
    chmod +x /usr/local/bin/test_agent.py

# Switch to agent user
USER agent
WORKDIR /workspaces

# Set environment variables
ENV USER=agent
ENV HOME=/home/agent
ENV PYTHONPATH=/usr/local/bin:$PYTHONPATH

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD [ "python3", "/usr/local/bin/test_agent.py" ]

# Default command shows the container is ready
CMD ["python3", "/usr/local/bin/test_agent.py"]